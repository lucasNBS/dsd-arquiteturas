generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model MenuItem {
  id String @id @default(uuid())
  name String
  description String?
  price Decimal
  available Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
